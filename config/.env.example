# Параметры сборки/обновления telemt-контейнера.
# Этот файл копируется установщиком в /opt/telemt/.env и правится
# командами --set-version / --auto-update.

# Конкретный тег официального образа ghcr.io/telemt/telemt, который
# используется как build-arg и как тег локально собранного образа
# civisrom/mt-telemt. Всегда конкретная версия (X.Y.Z), не "latest".
TELEMT_VERSION=3.4.18

# Канал обновления:
#   latest  — авто-обновление подтягивает новейший semver-тег из GHCR
#             и пересобирает образ, если появилась более новая версия.
#   pinned  — версия зафиксирована; авто-обновление ничего не меняет.
UPDATE_CHANNEL=latest
